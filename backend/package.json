{
  "name": "dealflow-ai-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon server.js",
    "workers": "node queues/workers/index.js",
    "dev:all": "concurrently -k -n api,workers -c cyan,magenta \"nodemon server.js\" \"node queues/workers/index.js\"",
    "start": "node server.js",
    "migrate": "prisma db push --schema ./models/prisma/schema.prisma",
    "setup": "npm run migrate && npm run seed",
    "seed": "node seeds/index.js",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "@prisma/client": "^5.7.1",
    "prisma": "^5.7.1",
    "ioredis": "^5.3.2",
    "bullmq": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.11.0",
    "openai": "^4.24.1",
    "twilio": "^4.20.0",
    "axios": "^1.6.2",
    "papaparse": "^5.4.1",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.0",
    "socket.io": "^4.7.2",
    "express-rate-limit": "^7.1.4",
    "multer": "^1.4.5-lts.1",
    "@sendgrid/mail": "^8.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
